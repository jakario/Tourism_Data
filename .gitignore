# Database files — keep .db out of git, but commit the pre-built cache
# data/tourism_cache.db is committed so Netlify build can use it
data/*.db-wal
data/*.db-shm

# Python cache
__pycache__/
*.pyc
*.pyo

# Config with API keys (keep template, ignore actual)
config/config.yaml
!config/config.yaml.template

# OS files
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Logs
*.log
/tmp/

# Netlify build output (generated by `netlify.toml build command`)
public/
!public/.gitkeep

# Netlify function — DB copy copied during build
netlify/functions/data/

# IDE
.idea/
.vscode/
*.swp
*.swo
